{
  "name": "esmenails",
  "private": true,
  "version": "0.0.0",
  "main": "desktop/electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm --prefix server run dev",
    "desktop:dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"wait-on tcp:5173 tcp:4000 && electron .\"",
    "build": "vite build",
    "build:client": "vite build",
    "desktop:build": "set VITE_APP_BASE=./&& npm run build && electron-builder --win nsis portable",
    "desktop:build:portable": "set VITE_APP_BASE=./&& npm run build && electron-builder --win portable",
    "desktop:build:installer": "set VITE_APP_BASE=./&& npm run build && electron-builder --win nsis",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run android:sync",
    "start:server": "npm --prefix server run start",
    "backup:db": "node scripts/backup/backup-db.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "@tailwindcss/vite": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@eslint/js": "^9.39.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.esmenails.desktop",
    "productName": "EsmeNails",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "desktop/**",
      "server/src/**",
      "server/package.json",
      "server/node_modules/**",
      "public/**"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
